---
/**
 * Base.astro — shell layout for every portal page.
 *
 * oauth2-proxy injects these headers on every authenticated request:
 *   X-Auth-Request-User, X-Auth-Request-Email, X-Auth-Request-Groups
 *   Authorization: Bearer <token>
 *
 * Astro reads them from Astro.request.headers and injects them into
 * <meta> tags so client-side Vue islands can read them without an
 * extra round-trip.  In static/preview mode the headers will be absent
 * and the meta tags will be empty — the UI degrades gracefully.
 */
interface Props {
  title?: string;
}

const { title = 'AF MCP Platform' } = Astro.props;

const headers = Astro.request.headers;
const userEmail    = headers.get('x-auth-request-email')    ?? '';
const userName     = headers.get('x-auth-request-user')     ?? '';
const userGroups   = headers.get('x-auth-request-groups')   ?? '';
// Strip "Bearer " prefix if present so the meta tag holds just the token.
const rawAuth      = headers.get('authorization')           ?? '';
const token        = rawAuth.startsWith('Bearer ') ? rawAuth.slice(7) : rawAuth;

const navLinks = [
  { href: '/',            label: 'Overview' },
  { href: '/catalog',     label: 'Tool Catalog' },
  { href: '/identities',  label: 'Identities' },
  { href: '/status',      label: 'AMI Proxy' },
];

const currentPath = new URL(Astro.request.url).pathname.replace(/\/$/, '') || '/';
---

<!doctype html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — AF MCP Platform</title>

  <!-- Identity & auth meta tags — read by src/lib/auth.ts and api.ts -->
  <meta name="af-user-email"    content={userEmail} />
  <meta name="af-user-username" content={userName} />
  <meta name="af-user-groups"   content={userGroups} />
  <meta name="af-token"         content={token} />

  <!-- IBM Plex — the type system that grounds this design in instrumentation -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
    rel="stylesheet"
  />

  <style>
    /* -----------------------------------------------------------------------
       CSS custom properties — single source of truth for the palette.
       Tailwind config mirrors these values; touch only here if you change color.
    ----------------------------------------------------------------------- */
    :root {
      --ground:   #0A0E1A;
      --surface:  #111827;
      --border:   #1F2937;
      --muted:    #374151;
      --dim:      #6B7280;
      --text:     #E8ECF0;
      --accent:   #00D4C8;   /* Cherenkov teal */
      --accent-2: #F59E0B;   /* calorimeter amber — warnings, state-change */
      --error:    #EF4444;
      --ok:       #10B981;
    }

    * { box-sizing: border-box; }

    html, body {
      background: var(--ground);
      color: var(--text);
      font-family: 'IBM Plex Sans', system-ui, sans-serif;
      font-size: 15px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      min-height: 100%;
    }

    /* Skip link for keyboard accessibility */
    .skip-link {
      position: absolute;
      top: -100%;
      left: 1rem;
      background: var(--accent);
      color: var(--ground);
      padding: 0.5rem 1rem;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.75rem;
      font-weight: 600;
      text-decoration: none;
      z-index: 1000;
    }
    .skip-link:focus { top: 1rem; }

    /* Nav ------------------------------------------------------------------ */
    .af-nav {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(10, 14, 26, 0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 0;
      padding: 0 2rem;
      height: 56px;
    }

    .af-nav__logo {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.875rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      color: var(--accent);
      text-decoration: none;
      white-space: nowrap;
      margin-right: 3rem;
      text-transform: uppercase;
    }

    .af-nav__links {
      display: flex;
      align-items: stretch;
      gap: 0;
      list-style: none;
      margin: 0;
      padding: 0;
      height: 100%;
    }

    .af-nav__link {
      display: flex;
      align-items: center;
      padding: 0 1.25rem;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--dim);
      border-bottom: 2px solid transparent;
      transition: color 150ms, border-color 150ms;
    }

    .af-nav__link:hover,
    .af-nav__link:focus-visible {
      color: var(--text);
      border-bottom-color: var(--muted);
      outline: none;
    }

    .af-nav__link[aria-current="page"] {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }

    .af-nav__spacer { flex: 1; }

    .af-nav__user {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.6875rem;
      color: var(--dim);
      letter-spacing: 0.04em;
    }

    /* Main content --------------------------------------------------------- */
    .af-main {
      min-height: calc(100vh - 56px - 48px);
      padding: 2.5rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
    }

    /* Footer --------------------------------------------------------------- */
    .af-footer {
      border-top: 1px solid var(--border);
      padding: 0 2rem;
      height: 48px;
      display: flex;
      align-items: center;
      gap: 2rem;
    }

    .af-footer__text {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.6875rem;
      color: var(--dim);
      letter-spacing: 0.04em;
    }

    .af-footer__link {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.6875rem;
      color: var(--dim);
      letter-spacing: 0.04em;
      text-decoration: none;
    }
    .af-footer__link:hover { color: var(--accent); }

    /* Responsive ----------------------------------------------------------- */
    @media (max-width: 640px) {
      .af-nav { padding: 0 1rem; }
      .af-nav__logo { margin-right: 1.5rem; font-size: 0.75rem; }
      .af-nav__link { padding: 0 0.75rem; font-size: 0.6875rem; }
      .af-nav__user { display: none; }
      .af-main { padding: 1.5rem 1rem; }
    }
  </style>
</head>
<body class="h-full">
  <a href="#main-content" class="skip-link">Skip to content</a>

  <nav class="af-nav" aria-label="Primary navigation">
    <a href="/" class="af-nav__logo" aria-label="AF MCP Platform home">
      AF&nbsp;/&nbsp;MCP
    </a>

    <ul class="af-nav__links" role="list">
      {navLinks.map(({ href, label }) => {
        const isActive = href === '/'
          ? currentPath === '/'
          : currentPath.startsWith(href);
        return (
          <li>
            <a
              href={href}
              class="af-nav__link"
              aria-current={isActive ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>

    <div class="af-nav__spacer" aria-hidden="true"></div>

    {userEmail && (
      <span class="af-nav__user" aria-label={`Signed in as ${userEmail}`}>
        {userEmail}
      </span>
    )}
  </nav>

  <main id="main-content" class="af-main">
    <slot />
  </main>

  <footer class="af-footer" aria-label="Site footer">
    <span class="af-footer__text">UChicago ATLAS Analysis Facility</span>
    <a
      href="https://af.uchicago.edu"
      class="af-footer__link"
      target="_blank"
      rel="noopener noreferrer"
    >
      af.uchicago.edu
    </a>
    <a
      href="https://atlas.cern"
      class="af-footer__link"
      target="_blank"
      rel="noopener noreferrer"
    >
      atlas.cern
    </a>
  </footer>
</body>
</html>
