---
/**
 * Base.astro — shell layout for every portal page.
 *
 * This is a static build. Identity is NOT read from request headers at render
 * time (those are empty in a static output and embedding a token would be an
 * XSS-exfiltration risk). Instead, on mount the inline script below checks
 * for a valid OIDC session (see ../lib/auth) — initiating the Authorization
 * Code + PKCE redirect if there isn't one — and once authenticated fills the
 * nav username (and any element tagged `data-af-identity`) from
 * GET /v1/identities, sent with the session's Bearer token (see ../lib/api).
 */
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'AF MCP Platform' } = Astro.props;

const navLinks = [
  { href: '/', label: 'Overview' },
  { href: '/catalog/', label: 'Tool Catalog' },
  { href: '/identities/', label: 'Identities' },
  { href: '/status/', label: 'AMI Proxy' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

// Inlined at build time from the PUBLIC_APP_VERSION build-arg (see
// Containerfile.portal); falls back to 'dev' for local `astro dev` and for
// a container built without the build-arg (ARG still sets ENV to an empty
// string in that case, so `||` is required here — `??` would not catch it).
const appVersion = import.meta.env.PUBLIC_APP_VERSION || 'dev';
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — AF MCP Platform</title>

    <style>
      /* -----------------------------------------------------------------------
       IBM Plex — self-hosted so the strict CSP (default-src 'self') can serve
       them without allowing fonts.googleapis.com / fonts.gstatic.com.
       woff2 files live in portal/public/fonts/.
    ----------------------------------------------------------------------- */
      @font-face {
        font-family: 'IBM Plex Sans';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/ibm-plex-sans-latin-400-normal.woff2') format('woff2');
      }
      @font-face {
        font-family: 'IBM Plex Sans';
        font-style: normal;
        font-weight: 500;
        font-display: swap;
        src: url('/fonts/ibm-plex-sans-latin-500-normal.woff2') format('woff2');
      }
      @font-face {
        font-family: 'IBM Plex Sans';
        font-style: normal;
        font-weight: 600;
        font-display: swap;
        src: url('/fonts/ibm-plex-sans-latin-600-normal.woff2') format('woff2');
      }
      @font-face {
        font-family: 'IBM Plex Mono';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/ibm-plex-mono-latin-400-normal.woff2') format('woff2');
      }
      @font-face {
        font-family: 'IBM Plex Mono';
        font-style: normal;
        font-weight: 500;
        font-display: swap;
        src: url('/fonts/ibm-plex-mono-latin-500-normal.woff2') format('woff2');
      }
      @font-face {
        font-family: 'IBM Plex Mono';
        font-style: normal;
        font-weight: 600;
        font-display: swap;
        src: url('/fonts/ibm-plex-mono-latin-600-normal.woff2') format('woff2');
      }
      @font-face {
        font-family: 'IBM Plex Mono';
        font-style: normal;
        font-weight: 700;
        font-display: swap;
        src: url('/fonts/ibm-plex-mono-latin-700-normal.woff2') format('woff2');
      }
    </style>

    <style>
      /* -----------------------------------------------------------------------
       All colour tokens live in src/styles/global.css inside the Tailwind
       `@theme` block. Reference them here as var(--color-af-*).
    ----------------------------------------------------------------------- */
      * {
        box-sizing: border-box;
      }

      html,
      body {
        background: var(--color-af-void);
        color: var(--color-af-text);
        font-family: 'IBM Plex Sans', system-ui, sans-serif;
        font-size: 15px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        min-height: 100%;
      }

      /* Skip link for keyboard accessibility */
      .skip-link {
        position: absolute;
        top: -100%;
        left: 1rem;
        background: var(--color-af-teal);
        color: var(--color-af-void);
        padding: 0.5rem 1rem;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        z-index: 1000;
      }
      .skip-link:focus {
        top: 1rem;
      }

      /* Nav ------------------------------------------------------------------ */
      .af-nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgb(from var(--color-af-void) r g b / 0.92);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--color-af-border);
        display: flex;
        align-items: center;
        gap: 0;
        padding: 0 2rem;
        height: 56px;
      }

      .af-nav__logo {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.875rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        color: var(--color-af-teal);
        text-decoration: none;
        white-space: nowrap;
        margin-right: 3rem;
        text-transform: uppercase;
      }

      .af-nav__links {
        display: flex;
        align-items: stretch;
        gap: 0;
        list-style: none;
        margin: 0;
        padding: 0;
        height: 100%;
      }

      .af-nav__link {
        display: flex;
        align-items: center;
        padding: 0 1.25rem;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        text-decoration: none;
        color: var(--color-af-dim);
        border-bottom: 2px solid transparent;
        transition:
          color 150ms,
          border-color 150ms;
      }

      .af-nav__link:hover,
      .af-nav__link:focus-visible {
        color: var(--color-af-text);
        border-bottom-color: var(--color-af-muted);
        outline: none;
      }

      .af-nav__link[aria-current='page'] {
        color: var(--color-af-teal);
        border-bottom-color: var(--color-af-teal);
      }

      .af-nav__spacer {
        flex: 1;
      }

      .af-nav__user {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.6875rem;
        color: var(--color-af-dim);
        letter-spacing: 0.04em;
      }

      /* Main content --------------------------------------------------------- */
      .af-main {
        min-height: calc(100vh - 56px - 48px);
        padding: 2.5rem 2rem;
        max-width: 1200px;
        margin: 0 auto;
        width: 100%;
      }

      /* Footer --------------------------------------------------------------- */
      .af-footer {
        border-top: 1px solid var(--color-af-border);
        padding: 0 2rem;
        height: 48px;
        display: flex;
        align-items: center;
        gap: 2rem;
      }

      .af-footer__text {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.6875rem;
        color: var(--color-af-dim);
        letter-spacing: 0.04em;
      }

      .af-footer__link {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.6875rem;
        color: var(--color-af-dim);
        letter-spacing: 0.04em;
        text-decoration: none;
      }
      .af-footer__link:hover {
        color: var(--color-af-teal);
      }

      .af-footer__version {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.625rem;
        color: var(--color-af-dim);
        letter-spacing: 0.04em;
        opacity: 0.6;
      }

      /* Responsive ----------------------------------------------------------- */
      @media (max-width: 640px) {
        .af-nav {
          padding: 0 1rem;
        }
        .af-nav__logo {
          margin-right: 1.5rem;
          font-size: 0.75rem;
        }
        .af-nav__link {
          padding: 0 0.75rem;
          font-size: 0.6875rem;
        }
        .af-nav__user {
          display: none;
        }
        .af-main {
          padding: 1.5rem 1rem;
        }
      }
    </style>

    <!--
    is:inline keeps this literally inline in the HTML instead of Astro
    bundling it into the external, hashed stylesheet (which is where the two
    <style> blocks above end up — check dist/*.html after a build if that's
    surprising). The auth-init script below can remove #af-auth-splash before
    that external stylesheet's <link> has even started fetching, so this
    block's rules need to be present the instant the element is parsed.
  -->
    <style is:inline>
      .af-auth-splash {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-af-void);
      }

      .af-auth-splash__inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }

      .af-auth-splash__spinner {
        width: 28px;
        height: 28px;
        border: 3px solid var(--color-af-border);
        border-top-color: var(--color-af-teal);
        border-radius: 50%;
        animation: af-auth-splash-spin 600ms linear infinite;
      }

      .af-auth-splash__inner p {
        margin: 0;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.8125rem;
        color: var(--color-af-dim);
        letter-spacing: 0.04em;
      }

      @keyframes af-auth-splash-spin {
        to {
          transform: rotate(360deg);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .af-auth-splash__spinner {
          animation: none;
          border-top-color: var(--color-af-dim);
        }
      }
    </style>
  </head>
  <body class="h-full">
    {
      // /callback runs its own OIDC exchange (see pages/callback.astro) and
      // has its own "Completing sign-in…" status UI — don't double it up.
      currentPath !== '/callback' && (
        <div id="af-auth-splash" class="af-auth-splash" role="status" aria-live="polite">
          <div class="af-auth-splash__inner">
            <div class="af-auth-splash__spinner" aria-hidden="true" />
            <p>Signing in…</p>
          </div>
        </div>
      )
    }

    <a href="#main-content" class="skip-link">Skip to content</a>

    <nav class="af-nav" aria-label="Primary navigation">
      <a href="/" class="af-nav__logo" aria-label="AF MCP Platform home"> AF&nbsp;/&nbsp;MCP </a>

      <ul class="af-nav__links" role="list">
        {
          navLinks.map(({ href, label }) => {
            const isActive =
              href === '/' ? currentPath === '/' : currentPath.startsWith(href.replace(/\/$/, ''));
            return (
              <li>
                <a href={href} class="af-nav__link" aria-current={isActive ? 'page' : undefined}>
                  {label}
                </a>
              </li>
            );
          })
        }
      </ul>

      <div class="af-nav__spacer" aria-hidden="true"></div>

      <span class="af-nav__user" data-af-identity aria-label="Signed in" hidden></span>
    </nav>

    <main id="main-content" class="af-main">
      <slot />
    </main>

    <footer class="af-footer" aria-label="Site footer">
      <span class="af-footer__text">UChicago ATLAS Analysis Facility</span>
      <span class="af-footer__version">v{appVersion}</span>
      <a
        href="https://af.uchicago.edu"
        class="af-footer__link"
        target="_blank"
        rel="noopener noreferrer"
      >
        af.uchicago.edu
      </a>
      <a
        href="https://atlas.cern"
        class="af-footer__link"
        target="_blank"
        rel="noopener noreferrer"
      >
        atlas.cern
      </a>
    </footer>

    <!--
    On mount: ensure an OIDC session exists (redirecting to Keycloak if not),
    then populate every [data-af-identity] element (nav username, hero
    greeting) from the broker. This is the only identity source in a static
    build.
  -->
    <script>
      import { fetchIdentities } from '../lib/api';
      import { getUser, isOidcConfigured, login } from '../lib/auth';

      (async () => {
        const splash = document.getElementById('af-auth-splash');

        try {
          const user = await getUser();
          if (!user) {
            // Don't redirect while /callback's own exchange is in flight —
            // that page runs the OIDC handshake itself and lands the user back
            // wherever they started once it completes (see pages/callback.astro).
            const path = window.location.pathname.replace(/\/$/, '') || '/';
            if (path !== '/callback') {
              if (await isOidcConfigured()) {
                // Leave the splash up — login() replaces this page with
                // Keycloak's redirect, so the last thing visible is the
                // splash rather than a flash of portal chrome.
                await login();
              } else {
                // Dev-bypass mode: no Keycloak in the loop to redirect to —
                // render the page unauthenticated.
                splash?.remove();
              }
            }
            return;
          }

          splash?.remove();
        } catch (err) {
          // getUser()/isOidcConfigured() already swallow config-load and
          // token errors internally (see ../lib/auth), but guard against
          // anything else throwing — render unauthenticated rather than
          // trap the user behind a permanent splash.
          console.warn(
            '[auth] session check failed unexpectedly — rendering unauthenticated.',
            err,
          );
          splash?.remove();
          return;
        }

        try {
          const id = await fetchIdentities();
          const label = id.email || id.unixname;
          if (!label) return;
          document.querySelectorAll<HTMLElement>('[data-af-identity]').forEach((el) => {
            el.textContent = label;
            const holder = el.closest<HTMLElement>('[data-af-user-holder]');
            if (holder) holder.hidden = false;
            else el.hidden = false;
          });
        } catch {
          // Session expired mid-page (broker 401'd after silent renew also
          // failed) — leave the identity slot hidden rather than looping.
        }
      })();
    </script>
  </body>
</html>
